<Window x:Class="OpenGameMate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenGameMate v0.1.0"
        Width="940"
        Height="780"
        MinWidth="760"
        MinHeight="620"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Grid Background="#F4F6F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="22,18" Background="#172033">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="White" FontSize="27" FontWeight="SemiBold" Text="OpenGameMate" />
                    <TextBlock x:Name="SubtitleText" Margin="0,4,0,0" Foreground="#C9D3E6"
                               Text="让 ChatGPT Voice 根据游戏画面自然陪聊" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Border Padding="12,6" CornerRadius="12" Background="#2A3853">
                        <TextBlock x:Name="StateText" Foreground="White" FontWeight="SemiBold" Text="Idle" />
                    </Border>
                    <ComboBox x:Name="LanguageComboBox" Margin="0,8,0,0" Width="150"
                              SelectionChanged="LanguageComboBox_SelectionChanged">
                        <ComboBoxItem Tag="ChineseSimplified">简体中文</ComboBoxItem>
                        <ComboBoxItem Tag="English">English</ComboBoxItem>
                        <ComboBoxItem Tag="System">跟随系统 / System</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14" Margin="0,0,0,12" CornerRadius="8" Background="#FFF4D6" BorderBrush="#E1B955" BorderThickness="1">
                    <TextBlock x:Name="PrivacySummaryText" TextWrapping="Wrap"
                               Text="OpenGameMate 只在你开始后捕获整个主显示器。它不读取回复、聊天记录、Cookie、Token 或音频。" />
                </Border>

                <GroupBox x:Name="BrowserGroup" Header="1. ChatGPT 与 Voice" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <WrapPanel>
                            <Button x:Name="OpenBrowserButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="OpenBrowserButton_Click" Content="打开 ChatGPT" />
                            <Button x:Name="ShowBrowserButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="ShowBrowserButton_Click" Content="显示" />
                            <Button x:Name="HideBrowserButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="HideBrowserButton_Click" Content="隐藏" />
                            <Button x:Name="CloseBrowserButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="CloseBrowserButton_Click" Content="关闭并结束 Voice" />
                        </WrapPanel>
                        <TextBlock x:Name="BrowserInstructionText" Margin="0,4,0,8" TextWrapping="Wrap"
                                   Text="请在独立窗口自行登录并开启 Voice，然后回到这里确认。" />
                        <Button x:Name="ConfirmVoiceButton" HorizontalAlignment="Left" Padding="14,7"
                                Click="ConfirmVoiceButton_Click" Content="我已开启 Voice" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="RoleGroup" Header="2. 可选角色初始化" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="RoleInstructionText" TextWrapping="Wrap"
                                   Text="首次使用可由你明确发送一次完整陪玩设定；不会自动发送。" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="SendFullRoleButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="SendFullRoleButton_Click" Content="发送完整设定" />
                            <Button x:Name="SendShortRoleButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="SendShortRoleButton_Click" Content="发送简短提醒" />
                            <Button x:Name="NewConversationButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="NewConversationButton_Click" Content="已新建对话，不发送提醒" />
                        </WrapPanel>
                        <TextBlock x:Name="RoleStatusText" Foreground="#566" Text="尚未记录角色初始化。" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="RunGroup" Header="3. 陪玩控制" Margin="0,0,0,12">
                    <StackPanel Margin="12">
                        <TextBlock x:Name="RunInstructionText" TextWrapping="Wrap"
                                   Text="开始 30 秒后首次自动发送，之后每 2 分钟一次。手动发送不重置计时，普通失败不立即重试。" />
                        <WrapPanel Margin="0,8,0,0">
                            <Button x:Name="StartButton" Padding="16,8" Margin="0,0,8,8"
                                    Click="StartButton_Click" Content="开始陪玩" />
                            <Button x:Name="SendNowButton" Padding="16,8" Margin="0,0,8,8"
                                    Click="SendNowButton_Click" Content="立即发送" />
                            <Button x:Name="PauseResumeButton" Padding="16,8" Margin="0,0,8,8"
                                    Click="PauseResumeButton_Click" Content="暂停" />
                            <Button x:Name="StopButton" Padding="16,8" Margin="0,0,8,8"
                                    Click="StopButton_Click" Content="停止" />
                        </WrapPanel>
                        <TextBlock x:Name="RunStatusText" Margin="0,4,0,0" Foreground="#455" TextWrapping="Wrap"
                                   Text="等待打开 ChatGPT。" />
                    </StackPanel>
                </GroupBox>

                <GroupBox x:Name="MaintenanceGroup" Header="4. 数据、规则与诊断">
                    <StackPanel Margin="12">
                        <WrapPanel>
                            <Button x:Name="RetryAdapterButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="RetryAdapterButton_Click" Content="重新检查内置规则" />
                            <Button x:Name="ExportDiagnosticsButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="ExportDiagnosticsButton_Click" Content="导出诊断包" />
                            <Button x:Name="OpenDataFolderButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="OpenDataFolderButton_Click" Content="打开数据目录" />
                            <Button x:Name="BrowserDataHelpButton" Padding="14,7" Margin="0,0,8,8"
                                    Click="BrowserDataHelpButton_Click" Content="浏览器数据清理说明" />
                        </WrapPanel>
                        <TextBlock x:Name="RemoteRulesText" Margin="0,4,0,0" Foreground="#566" TextWrapping="Wrap"
                                   Text="远程规则：未配置官方仓库和签名公钥，安全使用内置规则。" />
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <GroupBox x:Name="ActivityGroup" Grid.Row="2" Header="活动记录（不含网页内容）" Margin="18,0,18,14">
            <ListBox x:Name="ActivityList" Margin="8" />
        </GroupBox>
    </Grid>
</Window>
