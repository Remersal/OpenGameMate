<Window x:Class="OpenGameMate.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenGameMate"
        Width="1480"
        Height="900"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="#F2EEEB"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <SolidColorBrush x:Key="ShellBackgroundBrush" Color="#F2EEEB" />
        <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F4F2" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#E4DEDA" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#262424" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#746F6C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2C2A29" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#46413F" />

        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F2EFED" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#D5CECA" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#EAE5E2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAA5A2" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F7F5F4" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E9E4E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Button" BasedOn="{StaticResource FlatButtonStyle}" />

        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <ContentPresenter Margin="14,12,14,0"
                                                  ContentSource="Header"
                                                  TextElement.FontSize="13"
                                                  TextElement.FontWeight="SemiBold"
                                                  TextElement.Foreground="{StaticResource PrimaryTextBrush}" />
                                <ContentPresenter Grid.Row="1" />
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="370" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="178" />
                </Grid.RowDefinitions>

                <Border Padding="22,18,22,16"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Text="OpenGameMate" />
                        <TextBlock x:Name="SubtitleText"
                                   Margin="0,5,0,15"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Text="让 ChatGPT Voice 根据游戏画面自然陪聊" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border HorizontalAlignment="Left"
                                    Padding="10,5"
                                    Background="#EAE6E3"
                                    CornerRadius="12">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="StateIndicator" Width="7" Height="7" Margin="0,0,7,0" Fill="#8C8784" />
                                    <TextBlock x:Name="StateText"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                </StackPanel>
                            </Border>
                            <ComboBox x:Name="LanguageComboBox"
                                      Grid.Column="1"
                                      Width="132"
                                      Height="29"
                                      Padding="7,2"
                                      Background="White"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      SelectionChanged="LanguageComboBox_SelectionChanged">
                                <ComboBoxItem Tag="ChineseSimplified">简体中文</ComboBoxItem>
                                <ComboBoxItem Tag="English">English</ComboBoxItem>
                                <ComboBoxItem Tag="System">跟随系统 / System</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              Padding="16,14,16,8"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Padding="12"
                                Margin="0,0,0,10"
                                Background="#FFF8E8"
                                BorderBrush="#E8D49A"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock x:Name="PrivacySummaryText"
                                       Foreground="#615844"
                                       FontSize="12"
                                       LineHeight="18"
                                       TextWrapping="Wrap"
                                       Text="OpenGameMate 只在你开始后捕获整个主显示器，不读取回复、聊天记录、Cookie、Token 或音频。" />
                        </Border>

                        <GroupBox x:Name="BrowserGroup" Header="1. ChatGPT 与 Voice">
                            <StackPanel Margin="14,10,14,14">
                                <WrapPanel>
                                    <Button x:Name="OpenBrowserButton"
                                            Margin="0,0,7,7"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="OpenBrowserButton_Click"
                                            Content="打开 ChatGPT" />
                                    <Button x:Name="ShowBrowserButton"
                                            Margin="0,0,7,7"
                                            Click="ShowBrowserButton_Click"
                                            Content="显示窗口" />
                                    <Button x:Name="HideBrowserButton"
                                            Margin="0,0,7,7"
                                            Click="HideBrowserButton_Click"
                                            Content="隐藏窗口" />
                                    <Button x:Name="CloseBrowserButton"
                                            Margin="0,0,0,7"
                                            Click="CloseBrowserButton_Click"
                                            Content="关闭网页" />
                                </WrapPanel>
                                <TextBlock x:Name="BrowserInstructionText"
                                           Margin="0,2,0,9"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Text="请在右侧页面登录并开启 Voice，然后在这里确认。" />
                                <Button x:Name="ConfirmVoiceButton"
                                        HorizontalAlignment="Left"
                                        Click="ConfirmVoiceButton_Click"
                                        Content="我已开启 Voice" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="RoleGroup" Header="2. 可选角色初始化">
                            <StackPanel Margin="14,10,14,14">
                                <TextBlock x:Name="RoleInstructionText"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Text="首次使用可由你明确发送一次完整陪玩设定。" />
                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="SendFullRoleButton"
                                            Margin="0,0,7,7"
                                            Click="SendFullRoleButton_Click"
                                            Content="发送完整设定" />
                                    <Button x:Name="SendShortRoleButton"
                                            Margin="0,0,7,7"
                                            Click="SendShortRoleButton_Click"
                                            Content="发送简短提醒" />
                                    <Button x:Name="NewConversationButton"
                                            Margin="0,0,0,7"
                                            Click="NewConversationButton_Click"
                                            Content="新对话，不发送" />
                                </WrapPanel>
                                <TextBlock x:Name="RoleStatusText"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Text="尚未记录角色初始化。" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="RunGroup" Header="3. 陪玩控制">
                            <StackPanel Margin="14,10,14,14">
                                <TextBlock x:Name="RunInstructionText"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Text="网页音频停止且页面空闲稳定约 10 秒后自动发送。" />
                                <WrapPanel Margin="0,8,0,0">
                                    <Button x:Name="StartButton"
                                            Margin="0,0,7,7"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Click="StartButton_Click"
                                            Content="开始陪玩" />
                                    <Button x:Name="SendNowButton"
                                            Margin="0,0,7,7"
                                            Click="SendNowButton_Click"
                                            Content="立即发送" />
                                    <Button x:Name="PauseResumeButton"
                                            Margin="0,0,7,7"
                                            Click="PauseResumeButton_Click"
                                            Content="暂停" />
                                    <Button x:Name="StopButton"
                                            Margin="0,0,0,7"
                                            Click="StopButton_Click"
                                            Content="停止" />
                                </WrapPanel>
                                <Grid Margin="0,1,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="HotKeyLabelText"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="12"
                                               Text="主动截图快捷键" />
                                    <TextBox x:Name="HotKeyTextBox"
                                             Grid.Column="1"
                                             MinWidth="105"
                                             Height="30"
                                             Padding="8,4"
                                             VerticalContentAlignment="Center"
                                             IsReadOnly="True"
                                             PreviewKeyDown="HotKeyTextBox_PreviewKeyDown" />
                                    <Button x:Name="ChangeHotKeyButton"
                                            Grid.Column="2"
                                            Margin="7,0,0,0"
                                            Padding="10,5"
                                            Click="ChangeHotKeyButton_Click"
                                            Content="更改" />
                                </Grid>
                                <TextBlock x:Name="RunStatusText"
                                           Margin="0,1,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Text="等待打开 ChatGPT。" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox x:Name="MaintenanceGroup" Header="4. 数据、规则与诊断">
                            <StackPanel Margin="14,10,14,14">
                                <WrapPanel>
                                    <Button x:Name="RetryAdapterButton"
                                            Margin="0,0,7,7"
                                            Click="RetryAdapterButton_Click"
                                            Content="重新检查规则" />
                                    <Button x:Name="ExportDiagnosticsButton"
                                            Margin="0,0,7,7"
                                            Click="ExportDiagnosticsButton_Click"
                                            Content="导出诊断包" />
                                    <Button x:Name="OpenDataFolderButton"
                                            Margin="0,0,7,7"
                                            Click="OpenDataFolderButton_Click"
                                            Content="打开数据目录" />
                                    <Button x:Name="BrowserDataHelpButton"
                                            Margin="0,0,0,7"
                                            Click="BrowserDataHelpButton_Click"
                                            Content="浏览器数据说明" />
                                </WrapPanel>
                                <TextBlock x:Name="RemoteRulesText"
                                           Margin="0,1,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           LineHeight="18"
                                           TextWrapping="Wrap"
                                           Text="远程规则未配置，安全使用内置规则。" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <GroupBox x:Name="ActivityGroup"
                          Grid.Row="2"
                          Margin="16,4,16,14"
                          Header="活动记录（不含网页内容）">
                    <ListBox x:Name="ActivityList"
                             Margin="10,8,10,10"
                             Padding="2"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="11"
                             Foreground="#5D5957"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                </GroupBox>
            </Grid>
        </Border>

        <Border x:Name="ChatGptPane"
                Grid.Column="1"
                Margin="12"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="14">
            <Grid ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Padding="20,0"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="BrowserPaneTitleText"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="ChatGPT" />
                            <TextBlock x:Name="BrowserPaneCaptionText"
                                       Margin="0,2,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="11"
                                       Text="内嵌网页 · 登录与 Voice 由你控制" />
                        </StackPanel>
                        <Border Grid.Column="1"
                                VerticalAlignment="Center"
                                Padding="10,5"
                                Background="#F2EFED"
                                CornerRadius="12">
                            <TextBlock x:Name="BrowserPaneStatusText"
                                       Foreground="#6D6865"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Text="尚未打开" />
                        </Border>
                    </Grid>
                </Border>

                <Grid x:Name="BrowserHost" Grid.Row="1" Background="White">
                    <Border x:Name="BrowserPlaceholder"
                            Panel.ZIndex="10"
                            Margin="22"
                            Background="#FBFAF9"
                            BorderBrush="#E8E3E0"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel Width="360"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="BrowserPlaceholderTitleText"
                                       HorizontalAlignment="Center"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Text="ChatGPT 将显示在这里" />
                            <TextBlock x:Name="BrowserPlaceholderDescriptionText"
                                       Margin="0,10,0,18"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="13"
                                       LineHeight="20"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       Text="点击左侧“打开 ChatGPT”，网页会直接嵌入 OpenGameMate，不再弹出独立窗口。" />
                            <Button HorizontalAlignment="Center"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OpenBrowserButton_Click"
                                    Content="打开 ChatGPT" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
